# Civitas backend local base
NODE_ENV=development
PORT=3000

# Local PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgres://civitas:civitas@localhost:5432/civitas

# Optional legacy Logto sample configuration.
# Not required for the Nivel 0 local base or GET /health.
# Keep unset unless you are explicitly working on the future authentication scope.

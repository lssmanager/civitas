# Civitas backend local/Docker base
NODE_ENV=development
PORT=3000

# Local PostgreSQL when backend runs on the host and postgres runs with Docker Compose.
DATABASE_URL=postgres://civitas:civitas@localhost:5432/civitas

# Docker Compose/Coolify equivalent for the backend container.
# In Compose, use the postgres service name instead of localhost:
# DATABASE_URL=postgres://civitas:civitas@postgres:5432/civitas

# Logto Fase 02: regular API access-token validation.
# LOGTO_ENDPOINT is the base tenant URL, e.g. https://your-tenant.logto.app or http://localhost:3001.
LOGTO_ENDPOINT=
# LOGTO_ISSUER must match the token issuer. For Logto this is usually <LOGTO_ENDPOINT>/oidc.
LOGTO_ISSUER=
# JWKS endpoint used by jose.createRemoteJWKSet. For Logto this is usually <LOGTO_ISSUER>/jwks.
LOGTO_JWKS_URL=
# Audience/resource indicator configured for the Civitas API in Logto.
# Keep this equal to frontend VITE_API_RESOURCE_INDICATOR.
LOGTO_API_RESOURCE_INDICATOR=

# Future Logto Management API / organization infrastructure.
# Kept documented for later phases, but not used by Fase 02 routes or requireAuth.
# Do not set these for /auth/test unless a future phase explicitly needs them.
# LOGTO_MANAGEMENT_API_TOKEN_ENDPOINT=
# LOGTO_MANAGEMENT_API_APPLICATION_ID=
# LOGTO_MANAGEMENT_API_APPLICATION_SECRET=
# LOGTO_MANAGEMENT_API_RESOURCE=

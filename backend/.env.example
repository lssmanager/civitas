# Civitas backend local/Docker base
NODE_ENV=development
PORT=3000

# External PostgreSQL used by the backend in every environment.
# Replace with the real host, port, database, user and password of your deployed database.
DATABASE_URL=postgres://user:password@your-postgres-host:5432/civitas
DATABASE_WAIT_TIMEOUT_MS=60000
DATABASE_WAIT_INTERVAL_MS=2000
DATABASE_CONNECT_TIMEOUT_MS=1500

# Example local variant if you still run PostgreSQL outside Docker on your machine:
# DATABASE_URL=postgres://civitas:civitas@localhost:5432/civitas

# Logto Fase 02: regular API access-token validation.
# LOGTO_ENDPOINT is the base tenant URL, e.g. https://your-tenant.logto.app or http://localhost:3001.
LOGTO_ENDPOINT=
# LOGTO_ISSUER must match the token issuer. For Logto this is usually <LOGTO_ENDPOINT>/oidc.
LOGTO_ISSUER=
# JWKS endpoint used by jose.createRemoteJWKSet. For Logto this is usually <LOGTO_ISSUER>/jwks.
LOGTO_JWKS_URL=
# Audience/resource indicator configured for the Civitas API in Logto.
# Keep this equal to frontend VITE_API_RESOURCE_INDICATOR.
LOGTO_API_RESOURCE_INDICATOR=

# Logto Management API credentials used by owner organization provisioning endpoints.
# These are not used by /health.
LOGTO_MANAGEMENT_API_TOKEN_ENDPOINT=
LOGTO_MANAGEMENT_API_APPLICATION_ID=
LOGTO_MANAGEMENT_API_APPLICATION_SECRET=
LOGTO_MANAGEMENT_API_RESOURCE=

# Global Logto roles allowed for organization users after provisioning.
# Keep empty for normal tenants: school admins, teachers and students should only
# receive organization roles such as Admin-org or Student-org. Never include
# owner_global here; reserve owner_global for internal Civitas platform owners.
CIVITAS_ALLOWED_ORG_USER_GLOBAL_ROLES=
# FluentCRM CRM integration (Fase 08). Optional at boot; required only for CRM sync operations.
FLUENTCRM_BASE_URL=
FLUENTCRM_USERNAME=
FLUENTCRM_APP_PASSWORD=
# Optional custom FluentCRM field key used to retain previous email during Logto -> CRM identity updates.
FLUENTCRM_PREVIOUS_EMAIL_FIELD_KEY=

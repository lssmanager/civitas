# Civitas Docker Compose defaults for production/Coolify.
# Vite variables are build-time values: set them before building/redeploying frontend.
# DATABASE_URL must point to an external PostgreSQL deployment.

DATABASE_URL=postgres://user:password@your-postgres-host:5432/civitas
DATABASE_WAIT_TIMEOUT_MS=60000
DATABASE_WAIT_INTERVAL_MS=2000
DATABASE_CONNECT_TIMEOUT_MS=1500

BACKEND_PORT=3000
BACKEND_PUBLIC_PORT=3000
FRONTEND_PUBLIC_PORT=5173
PREVIEW_ALLOWED_HOSTS=civitas.socialstudies.cloud

LOGTO_ISSUER=https://auth.learnsocialstudies.com/oidc
LOGTO_JWKS_URL=https://auth.learnsocialstudies.com/oidc/jwks
LOGTO_API_RESOURCE_INDICATOR=https://civitas.socialstudies.cloud/api
LOGTO_MANAGEMENT_API_TOKEN_ENDPOINT=https://auth.learnsocialstudies.com/oidc/token
LOGTO_MANAGEMENT_API_APPLICATION_ID=
LOGTO_MANAGEMENT_API_APPLICATION_SECRET=
LOGTO_MANAGEMENT_API_RESOURCE=https://default.logto.app/api

VITE_API_BASE_URL=https://civitas.socialstudies.cloud/api
VITE_API_RESOURCE_INDICATOR=https://civitas.socialstudies.cloud/api
VITE_ENABLE_LOGTO=true
VITE_LOGTO_ENDPOINT=https://auth.learnsocialstudies.com/
VITE_LOGTO_APP_ID=avc4zf5kjm5rgc5xgsegh
VITE_APP_REDIRECT_URI=https://civitas.socialstudies.cloud/callback
VITE_APP_SIGN_OUT_REDIRECT_URI=https://civitas.socialstudies.cloud

# Logto organization-user security: keep empty so organization users receive no
# global roles. Do not configure owner_global as a default Logto role.
CIVITAS_ALLOWED_ORG_USER_GLOBAL_ROLES=
# FluentCRM CRM integration (Fase 08). Optional at boot; required only for CRM sync operations.
FLUENTCRM_BASE_URL=
FLUENTCRM_USERNAME=
FLUENTCRM_APP_PASSWORD=
# Optional custom FluentCRM field key used to retain previous email during Logto -> CRM identity updates.
FLUENTCRM_PREVIOUS_EMAIL_FIELD_KEY=

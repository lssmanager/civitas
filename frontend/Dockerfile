FROM node:20-alpine AS runtime

WORKDIR /app

ARG VITE_API_BASE_URL
ARG VITE_API_RESOURCE_INDICATOR
ARG VITE_API_REQUEST_TIMEOUT_MS
ARG VITE_ENABLE_LOGTO
ARG VITE_LOGTO_ENDPOINT
ARG VITE_LOGTO_APP_ID
ARG VITE_APP_REDIRECT_URI
ARG VITE_APP_SIGN_OUT_REDIRECT_URI

ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_API_RESOURCE_INDICATOR=$VITE_API_RESOURCE_INDICATOR
ENV VITE_API_REQUEST_TIMEOUT_MS=$VITE_API_REQUEST_TIMEOUT_MS
ENV VITE_ENABLE_LOGTO=$VITE_ENABLE_LOGTO
ENV VITE_LOGTO_ENDPOINT=$VITE_LOGTO_ENDPOINT
ENV VITE_LOGTO_APP_ID=$VITE_LOGTO_APP_ID
ENV VITE_APP_REDIRECT_URI=$VITE_APP_REDIRECT_URI
ENV VITE_APP_SIGN_OUT_REDIRECT_URI=$VITE_APP_SIGN_OUT_REDIRECT_URI

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build > /tmp/frontend-build.log 2>&1 || (cat /tmp/frontend-build.log && exit 1)

EXPOSE 5173
CMD ["npm", "run", "preview", "--", "--host", "0.0.0.0", "--port", "5173"]

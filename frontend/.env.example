# Civitas frontend local/Docker base.
# IMPORTANT: Vite embeds VITE_* values at build time. In Docker/Coolify,
# set these before building/redeploying the frontend image.

# Browser-visible backend URL. Local development can use localhost.
# Production/Coolify builds must set this before building; for Civitas production use:
# VITE_API_BASE_URL=https://civitas.socialstudies.cloud/api
VITE_API_BASE_URL=http://localhost:3000

# Logto. Keep disabled for mock/local UI work without an identity provider.
# Production/Coolify: VITE_ENABLE_LOGTO=true
VITE_ENABLE_LOGTO=false
# Base tenant URL, e.g. https://auth.learnsocialstudies.com/ or http://localhost:3001.
VITE_LOGTO_ENDPOINT=
# SPA application ID from Logto Console.
VITE_LOGTO_APP_ID=
# API resource indicator/audience for Civitas backend. Must match backend LOGTO_API_RESOURCE_INDICATOR.
# Production/Coolify: VITE_API_RESOURCE_INDICATOR=https://civitas.socialstudies.cloud/api
VITE_API_RESOURCE_INDICATOR=
# Configure these exact URLs in Logto Console for local Vite.
VITE_APP_REDIRECT_URI=http://localhost:5173/callback
VITE_APP_SIGN_OUT_REDIRECT_URI=http://localhost:5173/

# Runtime-only setting for `vite preview` behind Coolify/reverse proxies.
# Add additional public frontend domains separated by commas.
PREVIEW_ALLOWED_HOSTS=civitas.socialstudies.cloud

# Civitas production build values:
# VITE_API_BASE_URL=https://civitas.socialstudies.cloud/api
# VITE_API_RESOURCE_INDICATOR=https://civitas.socialstudies.cloud/api
# VITE_ENABLE_LOGTO=true
# VITE_LOGTO_ENDPOINT=https://auth.learnsocialstudies.com/
# VITE_LOGTO_APP_ID=avc4zf5kjm5rgc5xgsegh
# VITE_APP_REDIRECT_URI=https://civitas.socialstudies.cloud/callback
# VITE_APP_SIGN_OUT_REDIRECT_URI=https://civitas.socialstudies.cloud

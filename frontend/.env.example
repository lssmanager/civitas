# Civitas frontend local/Docker base.
# IMPORTANT: Vite embeds VITE_* values at build time. In Docker/Coolify,
# set these before building/redeploying the frontend image.

# Browser-visible backend URL. For local Docker Compose this can be localhost
# because the request is made by the browser, not by another container.
VITE_API_BASE_URL=http://localhost:3000

# Logto Fase 02. Keep disabled for mock/local UI work without an identity provider.
VITE_ENABLE_LOGTO=false
# Base tenant URL, e.g. https://your-tenant.logto.app or http://localhost:3001.
VITE_LOGTO_ENDPOINT=
# SPA application ID from Logto Console.
VITE_LOGTO_APP_ID=
# API resource indicator/audience for Civitas backend. Must match backend LOGTO_API_RESOURCE_INDICATOR.
VITE_API_RESOURCE_INDICATOR=
# Configure these exact URLs in Logto Console for local Vite.
VITE_APP_REDIRECT_URI=http://localhost:5173/callback
VITE_APP_SIGN_OUT_REDIRECT_URI=http://localhost:5173/

# Runtime-only setting for `vite preview` behind Coolify/reverse proxies.
# Add additional public frontend domains separated by commas.
PREVIEW_ALLOWED_HOSTS=civitas.socialstudies.cloud
